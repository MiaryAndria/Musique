{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex items-center justify-center">
    <div class="glass-panel p-8 md:p-12 w-full max-w-md">
        
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-secondary/10 rounded-2xl mb-4">
                <i data-feather="user-plus" class="w-8 h-8 text-secondary"></i>
            </div>
            <h1 class="text-2xl font-bold text-heading">Créer un compte</h1>
            <p class="text-muted text-sm mt-2">Rejoignez l'espace musical</p>
        </div>

        {% for error in errors %}
            <div class="alert alert-error mb-4 shadow-sm">
                <i data-feather="alert-circle" class="w-5 h-5"></i>
                <span>{{ error }}</span>
            </div>
        {% endfor %}

        <form method="post" action="{{ path('app_register') }}">
            
            <div class="form-control w-full mb-4">
                <label class="label" for="input-nom">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="user" class="w-4 h-4"></i> Nom (optionnel)
                    </span>
                </label>
                <input 
                    type="text" 
                    id="input-nom"
                    name="nom" 
                    value="{{ last_nom }}" 
                    placeholder="Votre nom" 
                    class="input input-bordered w-full" 
                />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label" for="input-email">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="mail" class="w-4 h-4"></i> Email
                    </span>
                </label>
                <input 
                    type="email" 
                    id="input-email"
                    name="email" 
                    value="{{ last_email }}" 
                    placeholder="votre@email.com" 
                    class="input input-bordered w-full" 
                    required 
                    autofocus 
                />
            </div>

            <div class="form-control w-full mb-4">
                <label class="label" for="input-password">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="lock" class="w-4 h-4"></i> Mot de passe
                    </span>
                </label>
                <input 
                    type="password" 
                    id="input-password"
                    name="password" 
                    placeholder="••••••••" 
                    class="input input-bordered w-full" 
                    required 
                    minlength="4"
                />
            </div>

            <div class="form-control w-full mb-8">
                <label class="label" for="input-password-confirm">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="check" class="w-4 h-4"></i> Confirmer le mot de passe
                    </span>
                </label>
                <input 
                    type="password" 
                    id="input-password-confirm"
                    name="password_confirm" 
                    placeholder="••••••••" 
                    class="input input-bordered w-full" 
                    required 
                    minlength="4"
                />
            </div>

            <button type="submit" class="btn btn-secondary w-full text-lg mb-4">
                <i data-feather="user-plus" class="w-5 h-5 mr-2"></i> S'inscrire
            </button>

            <div class="text-center">
                <p class="text-muted text-sm">
                    Déjà un compte ? 
                    <a href="{{ path('app_login') }}" class="link link-primary font-semibold">Se connecter</a>
                </p>
            </div>
        </form>
    </div>
</div>
{% endblock %}
