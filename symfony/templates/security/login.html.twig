{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="min-h-[80vh] flex items-center justify-center">
    <div class="glass-panel p-8 md:p-12 w-full max-w-md">
        
        <div class="text-center mb-10">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-primary/10 rounded-2xl mb-4">
                <i data-feather="music" class="w-8 h-8 text-primary"></i>
            </div>
            <h1 class="text-2xl font-bold text-heading">Connexion</h1>
            <p class="text-muted text-sm mt-2">Accédez à votre espace musical</p>
        </div>

        {% if error %}
            <div class="alert alert-error mb-6 shadow-sm">
                <i data-feather="alert-circle" class="w-5 h-5"></i>
                <span>{{ error.messageKey|trans(error.messageData, 'security') }}</span>
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            
            <div class="form-control w-full mb-5">
                <label class="label" for="input-email">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="mail" class="w-4 h-4"></i> Email
                    </span>
                </label>
                <input 
                    type="email" 
                    id="input-email"
                    name="_username" 
                    value="{{ last_username }}" 
                    placeholder="votre@email.com" 
                    class="input input-bordered w-full text-lg" 
                    required 
                    autofocus 
                />
            </div>

            <div class="form-control w-full mb-8">
                <label class="label" for="input-password">
                    <span class="label-text font-semibold text-heading flex items-center gap-2">
                        <i data-feather="lock" class="w-4 h-4"></i> Mot de passe
                    </span>
                </label>
                <input 
                    type="password" 
                    id="input-password"
                    name="_password" 
                    placeholder="••••••••" 
                    class="input input-bordered w-full text-lg" 
                    required 
                />
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn btn-primary w-full text-lg mb-4">
                <i data-feather="log-in" class="w-5 h-5 mr-2"></i> Se connecter
            </button>
            
            <div class="text-center">
                <p class="text-muted text-sm">
                    Pas encore de compte ? 
                    <a href="{{ path('app_register') }}" class="link link-secondary font-semibold">S'inscrire</a>
                </p>
            </div>
        </form>
    </div>
</div>
{% endblock %}
