{% extends 'base.html.twig' %}

{% block title %}Mes Playlists{% endblock %}

{% block body %}
<div class="page-header flex justify-between items-end">
    <div>
        <h1 class="page-title">
            <i data-feather="archive"></i> Mes Playlists
        </h1>
        <p class="text-muted mt-1">Retrouvez et téléchargez vos anciennes playlists générées.</p>
    </div>
    <a href="{{ path('app_playlist_create') }}" class="btn btn-primary">
        <i data-feather="plus" class="w-4 h-4 mr-2"></i> Nouvelle Playlist
    </a>
</div>

<div class="glass-panel overflow-x-auto">
    <table class="table w-full">
        <thead>
            <tr>
                <th>Nom de la Playlist</th>
                <th>Date de création</th>
                <th>Durée</th>
                <th>Morceaux</th>
                <th>Statut</th>
                <th class="text-right">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for playlist in playlists %}
            <tr class="hover:bg-base-200/50 transition-colors">
                <td class="font-medium text-heading">
                    <div class="flex items-center gap-3">
                        <div class="avatar placeholder">
                            <div class="bg-base-300 text-base-content rounded-xl w-10">
                                <span><i data-feather="music" class="w-4 h-4"></i></span>
                            </div>
                        </div>
                        {{ playlist.nom }}
                    </div>
                </td>
                <td class="text-muted">{{ playlist.createdAt|date('d/m/Y H:i') }}</td>
                <td>
                    <div class="badge badge-neutral">
                        {{ (playlist.dureeTotale / 60)|round(0, 'floor') }} min {{ playlist.dureeTotale % 60 }} s
                    </div>
                </td>
                <td class="text-muted">{{ playlist.songs|length }} morceaux</td>
                <td>
                    {% if playlist.downloaded %}
                        <div class="badge badge-success gap-1">
                            <i data-feather="check" class="w-3 h-3"></i> Téléchargé
                        </div>
                    {% else %}
                        <div class="badge badge-warning gap-1">
                            <i data-feather="clock" class="w-3 h-3"></i> Non téléchargé
                        </div>
                    {% endif %}
                </td>
                <td class="text-right space-x-2">
                    <a href="{{ path('app_playlist_show', {'id': playlist.id}) }}" class="btn btn-ghost btn-sm btn-circle tooltip" data-tip="Écouter">
                        <i data-feather="play-circle" class="w-4 h-4 text-primary"></i>
                    </a>
                    {% if not playlist.downloaded %}
                    <a href="{{ path('app_playlist_download', {'id': playlist.id}) }}" class="btn btn-ghost btn-sm btn-circle tooltip" data-tip="Télécharger le ZIP">
                        <i data-feather="download" class="w-4 h-4 text-secondary"></i>
                    </a>
                    {% else %}
                    <a href="{{ path('app_playlist_download', {'id': playlist.id}) }}" class="btn btn-ghost btn-sm btn-circle tooltip opacity-40" data-tip="Re-télécharger">
                        <i data-feather="download-cloud" class="w-4 h-4 text-base-content"></i>
                    </a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center py-12 text-muted">
                    <i data-feather="inbox" class="w-12 h-12 mx-auto mb-3 opacity-20"></i>
                    <p>Aucune playlist sauvegardée pour le moment.</p>
                    <a href="{{ path('app_playlist_create') }}" class="btn btn-outline btn-sm mt-4">Créer ma première playlist</a>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
