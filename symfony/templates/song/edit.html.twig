{% extends 'base.html.twig' %}

{% block title %}Modifier la Musique{% endblock %}

{% block body %}
<div class="page-header">
    <div class="flex items-center gap-4">
        <a href="{{ path('app_song_index') }}" class="btn btn-circle btn-sm btn-ghost">
            <i data-feather="arrow-left" class="w-4 h-4"></i>
        </a>
        <div>
            <h1 class="page-title">Éditer le morceau</h1>
            <p class="text-muted mt-1">{{ song.filename }}</p>
        </div>
    </div>
</div>

<div class="glass-panel max-w-2xl mx-auto p-6 md:p-8">
    <form method="post" action="{{ path('app_song_edit', {'id': song.id}) }}">
        
        <div class="form-control w-full mb-4">
            <label class="label">
                <span class="label-text font-medium text-heading">Titre</span>
            </label>
            <input type="text" name="title" value="{{ song.title }}" placeholder="Titre de la chanson" class="input input-bordered w-full" />
        </div>

        <div class="form-control w-full mb-6">
            <label class="label">
                <span class="label-text font-medium text-heading">Album</span>
            </label>
            <input type="text" name="album" value="{{ song.album }}" placeholder="Nom de l'album" class="input input-bordered w-full" />
        </div>

        <!-- Section modifiable pour artistes et genres -->
        <div class="form-control w-full mb-6">
            <label class="label">
                <span class="label-text font-medium text-heading">Artistes (séparés par virgule, 'x', ou 'feat')</span>
            </label>
            {% set artistNames = [] %}
            {% for artiste in song.artistes %}
                {% set artistNames = artistNames|merge([artiste.nom]) %}
            {% endfor %}
            <input type="text" name="artistes" value="{{ artistNames|join(', ') }}" placeholder="Nom de l'artiste" class="input input-bordered w-full" />
        </div>

        <div class="form-control w-full mb-6">
            <label class="label">
                <span class="label-text font-medium text-heading">Genres (séparés par virgule)</span>
            </label>
            {% set genreNames = [] %}
            {% for genre in song.genres %}
                {% set genreNames = genreNames|merge([genre.nom]) %}
            {% endfor %}
            <input type="text" name="genres" value="{{ genreNames|join(', ') }}" placeholder="Genre musical" class="input input-bordered w-full" />
        </div>

        <div class="metadata-box">
            <div class="flex items-center gap-2 mb-2 text-heading font-medium">
                <i data-feather="info" class="w-4 h-4"></i> Informations non modifiables
            </div>
            <p class="text-muted">
                <span class="metadata-label">Durée :</span> {{ (song.duration / 60)|round(0, 'floor') }}m {{ song.duration % 60 }}s
            </p>
        </div>

        <div class="flex justify-between items-center mt-6 pt-4 border-t border-base-200">
            <button type="submit" class="btn btn-primary px-8">
                <i data-feather="save" class="w-4 h-4 mr-2"></i> Enregistrer
            </button>
        </div>
    </form>
    
    <div class="mt-6 flex justify-end">
        <form method="post" action="{{ path('app_song_delete', {'id': song.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette chanson ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ song.id) }}">
            <button class="btn btn-error btn-outline btn-sm">
                <i data-feather="trash-2" class="w-4 h-4 mr-1"></i> Supprimer
            </button>
        </form>
    </div>
</div>
{% endblock %}
